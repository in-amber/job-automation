{
  "name": "01_ingest_jobs",
  "nodes": [
    {
      "parameters": {
        "rule": {
          "interval": [
            {
              "field": "hours",
              "hoursInterval": 6
            }
          ]
        }
      },
      "name": "Schedule Trigger",
      "type": "n8n-nodes-base.scheduleTrigger",
      "position": [250, 300],
      "typeVersion": 1
    },
    {
      "parameters": {
        "command": "python /home/node/scripts/ingest/fetch_jobs.py --source all"
      },
      "name": "Fetch Jobs",
      "type": "n8n-nodes-base.executeCommand",
      "position": [450, 300],
      "typeVersion": 1,
      "notes": "Fetch raw jobs from configured sources"
    },
    {
      "parameters": {
        "command": "python /home/node/scripts/ingest/normalize_jobs.py"
      },
      "name": "Normalize Jobs",
      "type": "n8n-nodes-base.executeCommand",
      "position": [650, 300],
      "typeVersion": 1,
      "notes": "Convert raw jobs to normalized format"
    },
    {
      "parameters": {
        "command": "python /home/node/scripts/ingest/dedupe_jobs.py"
      },
      "name": "Dedupe Jobs",
      "type": "n8n-nodes-base.executeCommand",
      "position": [850, 300],
      "typeVersion": 1,
      "notes": "Remove duplicate jobs"
    },
    {
      "parameters": {},
      "name": "Done",
      "type": "n8n-nodes-base.noOp",
      "position": [1050, 300],
      "typeVersion": 1
    }
  ],
  "connections": {
    "Schedule Trigger": {
      "main": [
        [
          {
            "node": "Fetch Jobs",
            "type": "main",
            "index": 0
          }
        ]
      ]
    },
    "Fetch Jobs": {
      "main": [
        [
          {
            "node": "Normalize Jobs",
            "type": "main",
            "index": 0
          }
        ]
      ]
    },
    "Normalize Jobs": {
      "main": [
        [
          {
            "node": "Dedupe Jobs",
            "type": "main",
            "index": 0
          }
        ]
      ]
    },
    "Dedupe Jobs": {
      "main": [
        [
          {
            "node": "Done",
            "type": "main",
            "index": 0
          }
        ]
      ]
    }
  },
  "settings": {
    "saveExecutionProgress": true,
    "saveManualExecutions": true
  },
  "tags": ["job-automation", "ingestion"]
}
