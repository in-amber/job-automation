{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "application_packet.schema.json",
  "title": "ApplicationPacket",
  "description": "Code-generated storage schema. Queue placement is authoritative runtime state, not this object.",
  "type": "object",
  "required": [
    "packet_id",
    "job_id",
    "company",
    "title",
    "apply_url",
    "ats_type",
    "trust_tier",
    "resume_path",
    "cover_letter_status",
    "applicant_answers_path",
    "job_snapshot_path",
    "screening_decision_path",
    "submit_policy",
    "escalation_policy",
    "created_at"
  ],
  "additionalProperties": false,
  "properties": {
    "packet_id": {
      "type": "string",
      "description": "Unique identifier for this packet"
    },
    "job_id": {
      "type": "string",
      "description": "Reference to the normalized job"
    },
    "company": {
      "type": "string"
    },
    "title": {
      "type": "string"
    },
    "location": {
      "type": ["string", "null"]
    },
    "source": {
      "type": "string"
    },
    "source_url": {
      "type": "string",
      "format": "uri"
    },
    "apply_url": {
      "type": "string",
      "format": "uri"
    },
    "ats_type": {
      "type": "string",
      "enum": ["linkedin_easy_apply", "greenhouse", "workday", "other"],
      "description": "Classified ATS system - computed by code, not AI"
    },
    "trust_tier": {
      "type": "string",
      "enum": ["tier_a", "tier_b", "tier_c"],
      "description": "Domain trust level - computed by code, not AI"
    },
    "resume_path": {
      "type": "string",
      "description": "Path to resume file"
    },
    "cover_letter_status": {
      "type": "string",
      "enum": [
        "not_needed",
        "predicted_needed_draft_pending",
        "draft_ready_waiting_approval",
        "approved",
        "required_discovered_mid_apply"
      ]
    },
    "cover_letter_path": {
      "type": ["string", "null"],
      "description": "Path to cover letter file. Must be non-null if cover_letter_status is 'approved'."
    },
    "applicant_answers_path": {
      "type": "string",
      "description": "Path to applicant master answers"
    },
    "job_snapshot_path": {
      "type": "string",
      "description": "Path to saved job details"
    },
    "screening_decision_path": {
      "type": "string",
      "description": "Path to screening decision JSON"
    },
    "submit_policy": {
      "type": "object",
      "required": ["human_approval_required", "auto_submit_allowed"],
      "additionalProperties": false,
      "properties": {
        "human_approval_required": {
          "type": "boolean",
          "description": "Whether human must approve before submission"
        },
        "auto_submit_allowed": {
          "type": "boolean",
          "description": "Whether automatic submission is permitted for this ATS"
        }
      }
    },
    "escalation_policy": {
      "type": "object",
      "required": ["manual_signup_only", "max_field_retries", "max_issue_minutes"],
      "additionalProperties": false,
      "properties": {
        "manual_signup_only": {
          "type": "boolean",
          "description": "If true, escalate on any signup requirement"
        },
        "max_field_retries": {
          "type": "integer",
          "minimum": 0,
          "description": "Maximum retries per field before escalation"
        },
        "max_issue_minutes": {
          "type": "integer",
          "minimum": 0,
          "description": "Maximum minutes on one unresolved issue"
        }
      }
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    },
    "updated_at": {
      "type": ["string", "null"],
      "format": "date-time"
    }
  },
  "if": {
    "properties": {
      "cover_letter_status": { "const": "approved" }
    }
  },
  "then": {
    "properties": {
      "cover_letter_path": {
        "type": "string",
        "minLength": 1
      }
    },
    "required": ["cover_letter_path"]
  }
}
